  --success:    #10B981;
  --warning:    #F59E0B;
  --danger:     #EF4444;
  --info:       #3B82F6;

  /* Ombres multicouches */
  --shadow-xs:  0 1px 2px rgba(15,27,53,0.04);
  --shadow-sm:  0 2px 8px rgba(15,27,53,0.06), 0 1px 2px rgba(15,27,53,0.04);
  --shadow-md:  0 4px 16px rgba(15,27,53,0.08), 0 2px 6px rgba(15,27,53,0.05);
