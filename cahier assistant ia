### ⚙️ CALLBACK PRINCIPAL — `callbacks/callbacks_hub_ia.py`

```python
import anthropic
import os
from dash import Input, Output, State, callback, no_update

client = anthropic.Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

@callback(
    [Output("seni-messages-store", "data"),
     Output("seni-chat-display",   "children"),
     Output("seni-input",          "value"),
     Output("seni-typing",         "style")],
    [Input("seni-send-btn",   "n_clicks"),
     Input("seni-input",      "n_submit")],
    [State("seni-input",          "value"),
     State("seni-messages-store", "data"),
     State("seni-mode-store",     "data"),
     State("store-filters",       "data"),
     State("store-kpis",          "data")],
    prevent_initial_call=True
)
def handle_seni_message(n_clicks, n_submit, user_input,
                         history, mode, filters, kpis):
    if not user_input or not user_input.strip():
        return no_update, no_update, no_update, {"display": "none"}

    # 1. Construire le system prompt selon le mode
    if mode == "analyse":
        system = build_analyse_prompt(kpis or {})
    elif mode == "glossaire":
        system = build_glossaire_prompt()
    else:
        system = build_rapport_prompt(kpis or {}, "Mars 2026")

    # 2. Historique (max 10 derniers tours)
    messages = (history or [])[-10:]
    messages.append({"role": "user", "content": user_input.strip()})

    # 3. Appel API Claude
    response = client.messages.create(
        model="claude-opus-4-5",
        max_tokens=400,
        system=system,
        messages=messages
    )
    reply = response.content[0].text

    # 4. Mise à jour historique
    messages.append({"role": "assistant", "content": reply})

    # 5. Rendu des bulles
    bubbles = render_chat_bubbles(messages)

    return messages, bubbles, "", {"display": "none"}
```

